{
  "name": "beam",
  "version": "0.1.0",
  "description": "Beam - Cast your screen to any device",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "build:preview": "eas build --platform ios --profile preview",
    "build:prod": "eas build --platform ios --profile production",
    "submit": "eas build --platform ios --profile production --auto-submit",
    "android": "expo run:android",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@videosdk.live/expo-ios-screen-share": "^0.0.3",
    "expo": "^57.0.4",
    "expo-asset": "^57.0.3",
    "expo-blur": "~57.0.0",
    "expo-constants": "~57.0.3",
    "expo-dev-client": "~57.0.5",
    "expo-device": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-notifications": "~57.0.3",
    "expo-router": "~57.0.4",
    "expo-status-bar": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-linear-gradient": "~2.8.0",
    "react-native-purchases": "^10.4.2",
    "react-native-purchases-ui": "^10.4.2",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-webrtc": "^124.0.4",
    "react-native-worklets": "0.10.0",
    "socket.io-client": "^4.8.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~19.2.4",
    "@types/uuid": "^10.0.0",
    "patch-package": "^8.0.1",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "@expo/fingerprint": "0.20.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-webrtc",
          "beam-nearby",
          "@videosdk.live/expo-ios-screen-share"
        ]
      }
    }
  },
  "private": true
}
